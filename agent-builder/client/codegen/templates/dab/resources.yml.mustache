resources:
  registered_models:
    agent_model:
      name: ${var.catalog}.${var.schema}.{{{bundleName}}}
      catalog_name: ${var.catalog}
      schema_name: ${var.schema}
      comment: "Generated by Databricks Agent Builder"

  model_serving_endpoints:
    agent_endpoint:
      name: {{{bundleName}}}-endpoint
      config:
        served_entities:
          - name: {{{bundleName}}}
            entity_name: ${var.catalog}.${var.schema}.{{{bundleName}}}
            entity_version: "1"
            scale_to_zero_enabled: true
            workload_size: Small
        auto_capture_config:
          catalog_name: ${var.catalog}
          schema_name: ${var.schema}
          table_name_prefix: {{{bundleName}}}
